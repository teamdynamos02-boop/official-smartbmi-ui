# FRONTEND SENSOR API CUSTOMIZATION HERE
# These values control how the website talks to the Flask sensor backend.
VITE_SENSOR_API_BASE=http://127.0.0.1:5000
VITE_SENSOR_WEIGHT_ENDPOINT=/sensor/weight
VITE_SENSOR_HEIGHT_ENDPOINT=/sensor/height
VITE_SENSOR_TIMEOUT_MS=6000
VITE_SENSOR_MEASURE_TIMEOUT_MS=12000
VITE_SENSOR_STABILITY_WINDOW_MS=1000
VITE_SENSOR_SAMPLE_INTERVAL_MS=150
VITE_SENSOR_MIN_STABLE_SAMPLES=4
VITE_SENSOR_WARMUP_SAMPLES=2
VITE_SENSOR_POST_STABLE_COLLECTION_MS=1200
VITE_SENSOR_NO_SERIAL_TIMEOUT_MS=2200
VITE_WEIGHT_STABILITY_TOLERANCE=0.4
VITE_HEIGHT_STABILITY_TOLERANCE=2
VITE_FACE_TIMEOUT_MS=20000
VITE_FACE_LIVENESS_TIMEOUT_MS=5000
VITE_FACE_REGISTER_TIMEOUT_MS=30000
VITE_BASIC_FACE_FLOW=false
VITE_FACE_REGISTER_SAMPLE_TARGET=6
VITE_FACE_IDENTIFY_REQUIRED_VOTES=2
VITE_FACE_IDENTIFY_MAX_NO_MATCH_RETRIES=2
VITE_FACE_IDENTIFY_STRONG_MATCH_MAX_DISTANCE=0.50
VITE_FACE_IDENTIFY_SINGLE_USER_MAX_DISTANCE=0.46
VITE_FACE_REGISTRATION_STEP_SETTLE_MS=750
VITE_FACE_REGISTRATION_CENTER_YAW_TOLERANCE=0.45
VITE_FACE_REGISTRATION_TURN_YAW_MIN_DELTA=0.015
VITE_FACE_REGISTRATION_TILT_PITCH_MIN_DELTA=0.005
VITE_FACE_REGISTRATION_LOOK_DOWN_PITCH_MIN_DELTA=0.003
VITE_FACE_REGISTRATION_POSE_COUNT=6
VITE_FACE_IDENTIFY_CLOSE_MATCH_RETRIES=1
VITE_FACE_FRAME_MAX_WIDTH=720
VITE_FACE_FRAME_MAX_HEIGHT=540
VITE_FACE_DECISION_TIMEOUT_MS=25000
VITE_FACE_GUEST_GATE_LIVENESS_MIN_SCORE=0.55
VITE_FACE_GUEST_GATE_LIVENESS_SOFT_SCORE=0.45
VITE_FACE_GUEST_BLINK_OPEN_MARGIN=0.06
VITE_FACE_GUEST_BLINK_EAR_DELTA=0.04
VITE_FACE_FRAME_JPEG_QUALITY=0.82
VITE_FACE_LANDMARK_OVERLAY=true
VITE_KIOSK_LIGHT_MOTION=true
VITE_CAMERA_MIRROR=true
VITE_CAMERA_FLIP_Y=false
VITE_CAMERA_ROTATE_180=true
VITE_LOCAL_DATA_BASE=http://127.0.0.1:5000
VITE_LOCAL_DATA_ENABLED=true
VITE_LOCAL_DATA_TIMEOUT_MS=3000
VITE_KIOSK_BLOCK_SHORTCUTS=true
VITE_KIOSK_DISABLE_CONTEXT_MENU=true
VITE_SYSTEM_STATUS_ENDPOINT=/system/status
VITE_SYSTEM_DEVICE_ID=smartbmi-kiosk-1
VITE_SYSTEM_MONITOR_POLL_MS=15000
VITE_SYSTEM_HISTORY_LIMIT=20
VITE_SYSTEM_HISTORY_INTERVAL_MS=60000
VITE_SYSTEM_STATUS_TIMEOUT_MS=3000

# BACKEND / SERIAL / TOF / FIREBASE CUSTOMIZATION HERE
SERIAL_PORT=/dev/serial/by-id/usb-Arduino__www.arduino.cc__0043_1453130343435171E0D2-if00
SERIAL_PORT_CANDIDATES=/dev/ttyACM0,/dev/ttyACM1,/dev/ttyUSB0,/dev/ttyUSB1
BAUD_RATE=115200
SERIAL_TIMEOUT=1
SERIAL_STARTUP_GRACE_MS=20000
SERIAL_STALE_REOPEN_MS=60000
SERIAL_COLD_BOOT_SUPPRESS_REOPEN_MS=90000
SERIAL_POST_RESET_WAIT_MS=3500
SERIAL_RECONNECT_INTERVAL_MS=5000
SERIAL_INCLUDE_UNDESCRIBED_PORTS=false
DEVICE_ID=smartbmi-kiosk-1
SYSTEM_CONNECTIVITY_HOST=8.8.8.8
SYSTEM_CONNECTIVITY_PORT=53
