FIREBASE_SYNC_BACKOFF_MIN_MS=30000
FIREBASE_SYNC_BACKOFF_MAX_MS=300000
FIREBASE_SYNC_SKIP_WHEN_OFFLINE=true
FIREBASE_RTDB_URL=https://smartbmi-demo-default-rtdb.firebaseio.com
