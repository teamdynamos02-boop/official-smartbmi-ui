FACE_DETECTION_FALLBACK_MODEL=cnn
FACE_ENROLL_NUM_JITTERS=3
FACE_IDENTIFY_NUM_JITTERS=2
FACE_MIN_FACE_SIZE_PX=110
FACE_BLINK_EAR_THRESHOLD=0.28
FACE_REGISTER_MIN_SAMPLES=5
FACE_LIVENESS_MODEL_PATH=models/face_liveness.onnx
FACE_LIVENESS_THRESHOLD=0.35
FACE_LIVENESS_INPUT_SIZE=112
FACE_CALIBRATION_ENABLED=true
FACE_CALIBRATION_LOG_FILE=face_calibration_log.jsonl
FACE_INSIGHTFACE_MODEL_PACK=buffalo_l
FACE_INSIGHTFACE_DET_WIDTH=640
FACE_INSIGHTFACE_DET_HEIGHT=640
FACE_MEDIAPIPE_MAX_FACES=1
FACE_PREPROCESS_ENABLE=true
FACE_PREPROCESS_CLAHE=true
FACE_PREPROCESS_CLAHE_CLIP=2.0
FACE_PREPROCESS_CLAHE_TILE=8
FACE_PREPROCESS_GAMMA=1.0
LOCAL_DATA_FILE=local_data.json
LOCAL_USERS_FILE=local_users.json
LOCAL_MEASUREMENTS_FILE=local_measurements.json
PENDING_SYNC_FILE=pending_sync.json
LOCAL_SYNC_INTERVAL_MS=30000
LOCAL_SYNC_BACKOFF_MS=60000
PI_CAMERA_WIDTH=1280
PI_CAMERA_HEIGHT=720
PI_CAMERA_JPEG_QUALITY=90
RESTRICTION_MODEL_PATH=models/restrictions.pt
RESTRICTION_CONFIDENCE=0.35

# RASPBERRY PI HARDWARE REPORTER CUSTOMIZATION HERE
SMARTBMI_BACKEND_URL=http://127.0.0.1:5000
SMARTBMI_OVERRIDE_ENDPOINT=/system/status/override
SMARTBMI_DEVICE_ID=smartbmi-kiosk-1
