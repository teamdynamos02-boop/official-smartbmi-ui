[Unit]
Description=SmartBMI Backend API
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=dynamos
Group=dynamos
WorkingDirectory=/home/dynamos/smartbmi-ui
ExecStartPre=/bin/sleep 15
ExecStart=/home/dynamos/smartbmi-ui/scripts/start_backend.sh
Restart=on-failure
RestartSec=5
TimeoutStartSec=90
TimeoutStopSec=20
KillMode=control-group
Environment=PYTHONUNBUFFERED=1
Environment=HOME=/home/dynamos
StandardOutput=journal
StandardError=journal
SyslogIdentifier=smartbmi-backend

[Install]
WantedBy=multi-user.target
